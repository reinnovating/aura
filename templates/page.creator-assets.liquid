<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <title>{{ page.title }} - {{ shop.name }}</title>
  <style>
    * {
      box-sizing: border-box;
    }
    body {
      margin: 0;
      padding: 0;
      font-family: Verdana, Geneva, sans-serif;
      background: #000;
      color: #fff;
    }
    .page-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 60px 20px;
    }
    .page-header {
      text-align: center;
      margin-bottom: 60px;
      border-bottom: 1px solid #333;
      padding-bottom: 40px;
    }
    .page-header h1 {
      font-family: Rockwell, Verdana, Geneva, sans-serif;
      font-size: 42px;
      margin: 0 0 16px;
      color: #fff;
    }
    .page-header p {
      font-size: 16px;
      color: #999;
      margin: 0;
      line-height: 1.6;
    }
    .content-wrapper {
      max-width: 900px;
      margin: 0 auto;
    }
    .footer-note {
      text-align: center;
      color: #666;
      font-size: 14px;
      margin: 60px 0 0;
      padding-top: 40px;
      border-top: 1px solid #333;
    }
    .footer-note a {
      color: #69e7c1;
      text-decoration: none;
    }
    @media (max-width: 640px) {
      .page-container {
        padding: 40px 16px;
      }
      .page-header h1 {
        font-size: 32px;
      }
    }
  </style>
</head>
<body>
  <div class="page-container">
    <div class="page-header">
      <h1>{{ page.title }}</h1>
      <p>Fresh creative assets for Claws x Code creators. Download, share, create.</p>
    </div>
    
    <div class="content-wrapper">
      {{ content_for_layout }}
    </div>
    
    <div class="footer-note">
      <p style="margin-top: 24px; font-size: 12px;">
        <a href="https://clawsxcode.com">← Back to Claws x Code</a>
      </p>
    </div>
  </div>
</body>
</html>