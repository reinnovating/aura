    function watchShadowRoot() {
      var host = document.getElementById(HOST_ID);
      if (!host || !host.shadowRoot) return;
      var shadowObserver = new MutationObserver(function() {
        inject();
      });
      shadowObserver.observe(host.shadowRoot, { childList: true, subtree: true });
    }
    var bodyObserver = new MutationObserver(function() {
      if (inject()) watchShadowRoot();
    });
    bodyObserver.observe(document.body, { childList: true, subtree: true });
    watchShadowRoot();
    document.addEventListener('DOMContentLoaded', function() { inject(); watchShadowRoot(); });
    setTimeout(function() { inject(); watchShadowRoot(); }, 1000);
    setTimeout(function() { inject(); watchShadowRoot(); }, 3000);
  })();
</script>